# Backend Environment Variables
# Copy this file to .env and fill in your values

# Required: Gemini API key(s) — comma-separated for key rotation
# GEMINI_API_KEY=your_key_here
# GEMINI_KEYS=key1,key2,key3

# Optional: MinerU Cloud API key (for advanced PDF extraction)
# MINERU_API_KEY=your_mineru_key_here

# Optional: Backend auth — set to require X-API-Key header on all endpoints
# API_KEY=your_backend_password

# Optional: CORS origins (comma-separated, default allows localhost only)
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: Database path (default: translator.db in current directory)
# TRANSLATOR_DB=./data/translator.db

# Optional: MinerU API base URL (default: https://mineru.net/api/v4)
# MINERU_API_BASE=https://mineru.net/api/v4

# Optional: Rate limit (requests per minute, default: 15 for free tier)
# GEMINI_RPM_LIMIT=15
